generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// CORE & MULTI-TENANCY (Synced via Clerk Webhooks)
// -----------------------------------------------------------------------------

enum WorkspaceType {
  CREATIVE
  EDUCATION
  RESEARCH
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

model Business {
  id              String        @id // Matches Clerk Organization ID
  name            String
  defaultCurrency String        @default("USD")
  workspaceType   WorkspaceType @default(CREATIVE)

  // Invoice & Email Settings
  invoicePrefix                String  @default("INV")
  invoiceSeparator             String  @default("-")
  invoiceSequence              Int     @default(0)
  clientSequence               Int     @default(0)
  projectSequence              Int     @default(0)
  emailSubjectTemplate         String  @default("Invoice {{invoice_number}} from {{business_name}}")
  emailBodyTemplate            String  @default("Hi {{client_name}},\n\nHere is your invoice for {{total_amount}}.\n\nDue Date: {{due_date}}\n\nThank you!")
  paymentInstructions          String  @default("Please send payment via bank transfer to:\nBank: \nAccount Number: \nRouting Number: ")
  feedbackEmailSubjectTemplate String  @default("We'd love your feedback on {{project_name}}")
  feedbackEmailBodyTemplate    String  @default("Hi {{client_name}},\n\nYour project \"{{project_name}}\" has just been delivered by {{business_name}}.\nWe hope you love the final result!\n\nCould you take 2 minutes to let us know how we did? Your feedback helps us improve and serve you better.\n\nThanks for trusting us with your project.\n- The {{business_name}} Team")
  // Messaging Settings
  realtimeMessagesEnabled      Boolean @default(false)

  // Subscription Details
  subscriptionPlan      SubscriptionPlan @default(FREE)
  subscriptionPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptionRequests SubscriptionRequest[]
  memberships        BusinessMembership[]
  clients            Client[]
  projects           Project[]
  workflowTemplates  WorkflowTemplate[]
  invoices           Invoice[]
  assets             Asset[]
  payments           Payment[]
  expenses           Expense[]
  creditNotes        CreditNote[]
  invoiceReminders   InvoiceReminder[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  feedbackRequests   FeedbackRequest[]
  feedbackResponses  FeedbackResponse[]
  testimonials       Testimonial[]
  reviewRequests     ReviewRequest[]
  analyticsSnapshots AnalyticsSnapshot[]
  projectRequests    ProjectRequest[]
  Conversation       Conversation[]

  @@map("businesses")
}

model User {
  id                      String   @id // Matches Clerk User ID
  email                   String   @unique
  firstName               String?
  lastName                String?
  imageUrl                String?
  navPreferences          Json?
  quickActionPreferences  Json?
  notificationPreferences Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  memberships             BusinessMembership[]
  notifications           Notification[]
  assignedProjects        Project[]
  ConversationParticipant ConversationParticipant[]
  Message                 Message[]
  timeEntries             TimeEntry[]

  @@map("users")
}

model BusinessMembership {
  id                  String   @id @default(cuid())
  businessId          String
  userId              String
  role                String // e.g., "org:admin", "org:member"
  weeklyCapacityHours Int      @default(40)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@map("business_memberships")
}

// -----------------------------------------------------------------------------
// SUBSCRIPTIONS & PAYMENTS
// -----------------------------------------------------------------------------

enum SubscriptionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model SubscriptionRequest {
  id             String                    @id @default(cuid())
  businessId     String
  planRequested  SubscriptionPlan
  transactionId  String                    @unique
  paymentMethod  String
  status         SubscriptionRequestStatus @default(PENDING)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
  @@map("subscription_requests")
}

// -----------------------------------------------------------------------------
// DOMAIN MODELS (Strictly partitioned by businessId)
// -----------------------------------------------------------------------------

model Client {
  id                      String   @id @default(cuid())
  businessId              String
  displayId               String?
  displayName             String
  companyName             String?
  email                   String?
  phone                   String?
  industry                String?
  preferredChannel        String?
  preferredDeliveryMethod String?
  internalRating          Int?     @default(0) // 1-5 stars
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  projects         Project[]
  invoices         Invoice[]
  feedbackRequests FeedbackRequest[]
  testimonials     Testimonial[]
  reviewRequests   ReviewRequest[]

  @@unique([businessId, displayId])
  @@unique([businessId, email]) // Prevent duplicate client emails within a business
  @@index([businessId]) // Critical for tenant data isolation performance
  @@map("clients")
}

model Project {
  id            String    @id @default(cuid())
  businessId    String
  displayId     String?
  clientId      String
  title         String
  type          String? // e.g., "YouTube Long-Form", "Corporate Ad"
  priority      String?
  deadline      DateTime?
  statusStageId String?
  orderIndex    Int       @default(0)
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business         Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client           Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  statusStage      WorkflowStage?        @relation(fields: [statusStageId], references: [id])
  assigneeId       String?
  assignee         User?                 @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  stageHistory     ProjectStageHistory[]
  invoices         Invoice[]
  notes            Note[]
  links            ProjectLink[]
  timeEntries      TimeEntry[]
  assets           ProjectAsset[]
  expenses         Expense[]
  feedbackRequests FeedbackRequest[]
  testimonials     Testimonial[]
  reviewRequests   ReviewRequest[]

  @@unique([businessId, displayId])
  @@index([businessId])
  @@index([clientId])
  @@index([statusStageId])
  @@map("projects")
}

// -----------------------------------------------------------------------------
// PRE-PRODUCTION: PROJECT REQUESTS
// -----------------------------------------------------------------------------

enum ProjectRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProjectRequest {
  id         String               @id @default(cuid())
  businessId String
  status     ProjectRequestStatus @default(PENDING)

  // Client info (stored as-is from the intake form)
  clientName       String
  clientEmail      String
  companyName      String?
  phone            String?
  industry         String?
  preferredChannel String?

  // Project info
  projectTitle   String
  projectType    String?
  scriptText     String? @db.Text
  scriptLink     String?
  rawFootageLink String?

  // Resolution
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
  @@map("project_requests")
}

// -----------------------------------------------------------------------------
// WORKFLOW ENGINE
// -----------------------------------------------------------------------------

model WorkflowTemplate {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  projectType String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stages   WorkflowStage[]

  @@index([businessId])
  @@map("workflow_templates")
}

model WorkflowStage {
  id             String  @id @default(cuid())
  templateId     String
  name           String
  orderIndex     Int
  estimatedHours Int?
  billingTrigger Boolean @default(false)
  icon           String?

  template WorkflowTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  projects Project[]
  history  ProjectStageHistory[]

  @@index([templateId])
  @@map("workflow_stages")
}

model ProjectStageHistory {
  id        String    @id @default(cuid())
  projectId String
  stageId   String
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage   WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([stageId])
  @@map("project_stage_history")
}

// -----------------------------------------------------------------------------
// FINANCIALS (V2)
// -----------------------------------------------------------------------------

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  CREDIT_NOTE
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CASH
  CHECK
  OTHER
}

model Invoice {
  id         String  @id @default(cuid())
  businessId String
  clientId   String
  projectId  String?

  invoiceNumber String // e.g. CUT-2026-0042
  currency      String @default("USD")

  // Money in cents
  subtotalCents   Int @default(0)
  taxRateBps      Int @default(0) // Basis points e.g. 2000 = 20%
  taxAmountCents  Int @default(0)
  totalCents      Int @default(0)
  amountPaidCents Int @default(0)
  amountDueCents  Int @default(0)

  // For reporting
  fxRateSnapshot Decimal? @db.Decimal(10, 6)

  status InvoiceStatus @default(DRAFT)
  notes  String?       @db.Text
  pdfUrl String?

  issuedAt      DateTime?
  dueDate       DateTime?
  paidAt        DateTime?
  emailSentAt   DateTime?
  reminderCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  lineItems   InvoiceLineItem[]
  payments    Payment[]
  creditNotes CreditNote[]
  reminders   InvoiceReminder[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int    @default(1)
  amountCents Int // Price per unit in cents

  // To trace back to origin
  sourceType String? @default("manual") // manual, milestone, revision
  sourceId   String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id          String        @id @default(cuid())
  businessId  String
  invoiceId   String
  amountCents Int
  method      PaymentMethod
  reference   String? // Check number, Stripe TX ID

  reconciledAt       DateTime?
  reconciledByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([invoiceId])
  @@map("payments")
}

model Expense {
  id         String  @id @default(cuid())
  businessId String
  projectId  String?

  amountCents    Int
  currency       String   @default("USD")
  fxRateSnapshot Decimal? @db.Decimal(10, 6)

  category     String // e.g. "Software", "Travel", "Contractor"
  description  String?
  dateIncurred DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([projectId])
  @@map("expenses")
}

model CreditNote {
  id                String @id @default(cuid())
  businessId        String
  originalInvoiceId String

  amountCents Int
  reason      String

  createdAt DateTime @default(now())

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  originalInvoice Invoice  @relation(fields: [originalInvoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([originalInvoiceId])
  @@map("credit_notes")
}

model InvoiceReminder {
  id         String @id @default(cuid())
  businessId String
  invoiceId  String

  tone    String // 'gentle', 'firm', 'final'
  channel String @default("email")

  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([invoiceId])
  @@map("invoice_reminders")
}

model AuditLog {
  id           String  @id @default(cuid())
  businessId   String
  entityType   String // 'Invoice', 'Payment'
  entityId     String // Polymorphic reference — intentionally no FK (can reference Invoice, Payment, etc.)
  action       String // 'CREATE', 'UPDATE', 'VOID', 'PAYMENT_RECORDED'
  actorUserId  String? // Intentionally not FK-constrained: audit logs must survive user deletion
  metadataJson String? @db.Text

  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// NOTES & TIME TRACKING
// -----------------------------------------------------------------------------

model Note {
  id        String   @id @default(cuid())
  projectId String
  type      String // 'shot', 'client', 'idea', 'todo'
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("notes")
}

model TimeEntry {
  id              String    @id @default(cuid())
  projectId       String
  userId          String?
  startedAt       DateTime?
  endedAt         DateTime?
  durationMinutes Int       @default(0)
  isBillable      Boolean   @default(true)
  source          String    @default("manual") // manual, stopwatch
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@map("time_entries")
}

// -----------------------------------------------------------------------------
// ASSET & LICENSE MANAGEMENT
// -----------------------------------------------------------------------------

model Asset {
  id          String    @id @default(cuid())
  businessId  String
  type        String // 'Music', 'Font', 'LUT', 'Plugin', 'Stock Footage', 'SFX', 'Motion Graphics'
  name        String
  vendor      String?
  licenseType String?
  expiresAt   DateTime?
  cost        Int       @default(0) // stored in cents
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  projects ProjectAsset[]

  @@unique([businessId, name, type]) // Prevent duplicate asset name+type within a business
  @@index([businessId])
  @@map("assets")
}

model ProjectAsset {
  id        String   @id @default(cuid())
  projectId String
  assetId   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([projectId, assetId])
  @@index([projectId])
  @@index([assetId])
  @@map("project_assets")
}

model ProjectLink {
  id        String   @id @default(cuid())
  projectId String
  url       String
  label     String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_links")
}

model Notification {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  title      String
  message    String
  type       String   @default("system") // e.g., 'invoice', 'project', 'client', 'system'
  isRead     Boolean  @default(false)
  actionUrl  String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId, userId])
  @@map("notifications")
}

// -----------------------------------------------------------------------------
// CLIENT FEEDBACK & TESTIMONIALS
// -----------------------------------------------------------------------------

model FeedbackRequest {
  id               String    @id @default(cuid())
  businessId       String
  projectId        String
  clientId         String
  token            String    @unique
  status           String    @default("PENDING") // PENDING, COMPLETED, EXPIRED
  sentAt           DateTime  @default(now())
  responseDeadline DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  response FeedbackResponse?

  @@index([businessId])
  @@index([projectId])
  @@index([clientId])
  @@index([token])
  @@map("feedback_requests")
}

model FeedbackResponse {
  id               String   @id @default(cuid())
  businessId       String
  requestId        String   @unique
  overallScore     Int
  dimensionScores  Json?
  commentText      String?  @db.Text
  videoUrl         String?
  consentToPublish Boolean  @default(false)
  submittedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  request     FeedbackRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  testimonial Testimonial?

  @@index([businessId])
  @@map("feedback_responses")
}

model Testimonial {
  id                 String    @id @default(cuid())
  businessId         String
  feedbackResponseId String    @unique
  projectId          String
  clientId           String
  displayText        String    @db.Text
  videoRef           String?
  isPublished        Boolean   @default(false)
  publishedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  feedbackResponse FeedbackResponse @relation(fields: [feedbackResponseId], references: [id], onDelete: Cascade)
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client           Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([projectId])
  @@index([clientId])
  @@map("testimonials")
}

// -----------------------------------------------------------------------------
// POST-PRODUCTION REVIEWS
// -----------------------------------------------------------------------------

model ReviewRequest {
  id          String   @id @default(cuid())
  businessId  String
  projectId   String
  clientId    String
  token       String   @unique
  draftLink   String?
  status      String   @default("PENDING") // PENDING, REPLIED
  clientNotes String?  @db.Text
  clientLinks String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([projectId])
  @@index([clientId])
  @@index([token])
  @@map("review_requests")
}

// -----------------------------------------------------------------------------
// ANALYTICS & REPORTING
// -----------------------------------------------------------------------------

model AnalyticsSnapshot {
  id         String   @id @default(cuid())
  businessId String
  date       DateTime @db.Date // The date this snapshot represents

  revenueMTDCents       Int
  revenueLastMonthCents Int
  revenueDelta          Float
  outstandingCents      Int
  overdueCents          Int
  utilization           Float
  atRiskCount           Int
  avgFeedback           Float
  dso                   Float

  historicalTrendJson Json?

  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId, date(sort: Desc)])
  @@map("analytics_snapshots")
}

// -----------------------------------------------------------------------------
// MESSAGING & BROADCASTS
// -----------------------------------------------------------------------------

enum ConversationType {
  DIRECT
  BROADCAST
  GROUP
}

model Conversation {
  id         String           @id @default(cuid())
  businessId String
  type       ConversationType
  title            String?
  slowModeEnabled  Boolean          @default(false)
  slowModeCooldown Int              @default(10)
  createdBy        String
  createdAt        DateTime         @default(now())

  business     Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([businessId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  isMuted        Boolean   @default(false)
  lastReadAt     DateTime?
  deletedAt      DateTime?
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String?
  content        String    @db.Text
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

// -----------------------------------------------------------------------------
// GLOBAL ADMIN
// -----------------------------------------------------------------------------

model GlobalAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("global_admins")
}
